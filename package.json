{
  "private": true,
  "version": "0.1.78",
  "packageManager": "pnpm@9.15.9",
  "workspaces": {
    "packages": [
      "apps/*"
    ],
    "nohoist": [
      "**/@eslint/**",
      "**/eslint"
    ]
  },
  "scripts": {
    "release": "pnpm dlx standard-version",
    "versao": "pnpm run release && git push --follow-tags",
    "install:all": "pnpm install",
    "check:theming": "node scripts/check-no-hardcoded-colors.js",
    "dev:backend": "corepack pnpm --filter backend start:dev",
    "dev:frontend": "corepack pnpm --filter frontend dev",
    "build:all": "corepack pnpm -r run build",
    "test:all": "corepack pnpm -r run test",
    "test:installer-regression": "node Scripts/tests/installer-redis-auth-regression.js",
    "clean": "pnpm -r exec rm -rf node_modules dist .next"
  },
  "overrides": {
    "diff": "^8.0.3",
    "multer": "^2.1.1",
    "socket.io-parser": "^4.2.6",
    "serialize-javascript": "^7.0.3",
    "standard-version>dotgitignore>minimatch": "^3.1.4",
    "@typescript-eslint/eslint-plugin>@typescript-eslint/type-utils>@typescript-eslint/typescript-estree>minimatch": "^9.0.7",
    "@nestjs/cli>glob>minimatch": "^10.2.3",
    "@nestjs/cli>fork-ts-checker-webpack-plugin>schema-utils>ajv": "^6.14.0",
    "@nestjs/cli>@angular-devkit/core>ajv": "^8.18.0"
  },
  "standard-version": {
    "tagPrefix": "v",
    "packageFiles": [
      "package.json",
      "apps/backend/package.json",
      "apps/frontend/package.json"
    ],
    "bumpFiles": [
      "package.json",
      "apps/backend/package.json",
      "apps/frontend/package.json"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@sentry/cli",
      "bcrypt",
      "core-js",
      "esbuild",
      "prisma",
      "puppeteer",
      "sharp"
    ],
    "overrides": {
      "diff": "^8.0.3",
      "multer": "^2.1.1",
      "socket.io-parser": "^4.2.6",
      "serialize-javascript": "^7.0.3"
    }
  }
}
