{
  "private": true,
  "version": "0.1.37",
  "workspaces": {
    "packages": [
      "apps/*"
    ],
    "nohoist": [
      "**/@eslint/**",
      "**/eslint"
    ]
  },
  "scripts": {
    "release": "standard-version",
    "versao": "pnpm run release && git push --follow-tags",
    "install:all": "pnpm install",
    "dev:backend": "pnpm --filter backend start:dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build:all": "pnpm -r run build",
    "test:all": "pnpm -r run test",
    "test:installer-regression": "node Scripts/tests/installer-redis-auth-regression.js",
    "clean": "pnpm -r exec rm -rf node_modules dist .next"
  },
  "overrides": {
    "diff": "^8.0.3",
    "multer": "^2.1.1",
    "serialize-javascript": "^7.0.3",
    "standard-version>dotgitignore>minimatch": "^3.1.4",
    "@typescript-eslint/eslint-plugin>@typescript-eslint/type-utils>@typescript-eslint/typescript-estree>minimatch": "^9.0.7",
    "@nestjs/cli>glob>minimatch": "^10.2.3",
    "@nestjs/cli>fork-ts-checker-webpack-plugin>schema-utils>ajv": "^6.14.0",
    "@nestjs/cli>@angular-devkit/core>ajv": "^8.18.0"
  },
  "devDependencies": {
    "standard-version": "^9.5.0"
  },
  "dependencies": {
    "googleapis": "^171.3.0"
  }
}
