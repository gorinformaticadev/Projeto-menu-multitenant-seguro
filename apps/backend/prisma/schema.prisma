generator client { 
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id              String            @id @default(uuid())
  email           String            @unique
  cnpjCpf         String            @unique
  nomeFantasia    String
  nomeResponsavel String
  telefone        String
  logoUrl         String?
  ativo           Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  isMasterTenant  Boolean           @default(false)
  tenantModules   ModuleTenant[]
  users           User[]

  @@index([ativo])
  @@index([createdAt])
  @@index([isMasterTenant])
  @@map("tenants")
}

model User {
  id                       String               @id @default(uuid())
  email                    String               @unique
  password                 String
  name                     String
  avatarUrl                String?
  role                     Role                 @default(USER)
  tenantId                 String?
  twoFactorSecret          String?
  twoFactorPendingSecret   String?
  twoFactorEnabled         Boolean              @default(false)
  emailVerified            Boolean              @default(false)
  emailVerificationToken   String?
  emailVerificationExpires DateTime?
  passwordHistory          String?
  lastPasswordChange       DateTime?
  sessionVersion           Int                  @default(0)
  loginAttempts            Int                  @default(0)
  isLocked                 Boolean              @default(false)
  lockedAt                 DateTime?
  lockedUntil              DateTime?
  lastFailedLoginAt        DateTime?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  auditLogs                AuditLog[]
  passwordResetTokens      PasswordResetToken[]
  refreshTokens            RefreshToken[]
  blacklistedTokens        BlacklistedToken[]
  trustedDevices           TrustedDevice[]
  trustedDevicesRevoked    TrustedDevice[]       @relation("TrustedDeviceRevokedBy")
  sessions                 UserSession[]
  tenant                   Tenant?              @relation(fields: [tenantId], references: [id])
  preferences              UserPreferences?
  backupLogs               BackupLog[]
  backupRestoreLogs        BackupRestoreLog[]
  backupArtifacts          BackupArtifact[]
  backupJobs               BackupJob[]          @relation("BackupJobCreatedBy")
  pushSubscriptions        PushSubscription[]
  seedHistory             SeedHistory[]
  dashboardLayouts        DashboardLayout[]

  @@index([tenantId])
  @@index([email])
  @@index([role])
  @@index([isLocked])
  @@index([tenantId, role])
  @@map("users")
}

model TrustedDevice {
  id              String    @id @default(uuid())
  userId          String
  tokenHash       String    @unique
  deviceLabel     String?
  userAgent       String?
  createdIp       String?
  lastUsedIp      String?
  createdAt       DateTime  @default(now())
  lastUsedAt      DateTime?
  expiresAt       DateTime
  revokedAt       DateTime?
  revokedByUserId String?
  revokeReason    String?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  revokedByUser   User?     @relation("TrustedDeviceRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([userId, revokedAt, expiresAt])
  @@map("trusted_devices")
}

model DashboardLayout {
  id          String   @id @default(uuid())
  userId      String
  role        Role
  layoutJson  Json     @default("{}")
  filtersJson Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
  @@index([role])
  @@index([updatedAt])
  @@map("dashboard_layouts")
}

model UserPreferences {
  id        String   @id @default(uuid())
  userId    String   @unique
  theme     String   @default("light")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  sessionId String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session   UserSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([token])
  @@index([expiresAt])
  @@index([userId, expiresAt])
  @@map("refresh_tokens")
}

model UserSession {
  id                  String         @id @default(uuid())
  userId              String
  tenantId            String?
  lastActivityAt      DateTime       @default(now())
  expiresAt           DateTime
  lastAuthenticatedAt DateTime       @default(now())
  lastIpAddress       String?
  lastUserAgent       String?
  revokedAt           DateTime?
  revokeReason        String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens       RefreshToken[]

  @@index([userId])
  @@index([expiresAt])
  @@index([tenantId])
  @@index([revokedAt])
  @@index([lastActivityAt])
  @@index([userId, revokedAt])
  @@map("user_sessions")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@index([usedAt])
  @@map("password_reset_tokens")
}

model BlacklistedToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("blacklisted_tokens")
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  severity    String   @default("info")
  message     String   @default("")
  userId      String?
  actorUserId String?
  actorEmail  String?
  actorRole   String?
  tenantId    String?
  ip          String?
  ipAddress   String?
  userAgent   String?
  details     String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([actorUserId])
  @@index([severity])
  @@index([tenantId])
  @@index([action])
  @@index([createdAt])
  @@index([tenantId, action, createdAt])
  @@index([userId, action, createdAt])
  @@map("audit_logs")
}

model SecurityConfig {
  id                         String   @id @default(uuid())
  loginMaxAttempts           Int      @default(5)
  loginLockDurationMinutes   Int      @default(30)
  loginWindowMinutes         Int      @default(1)
  globalMaxRequests          Int      @default(10000)
  globalWindowMinutes        Int      @default(1)
  passwordMinLength          Int      @default(8)
  passwordRequireUppercase   Boolean  @default(true)
  passwordRequireLowercase   Boolean  @default(true)
  passwordRequireNumbers     Boolean  @default(true)
  passwordRequireSpecial     Boolean  @default(true)
  accessTokenExpiresIn       String   @default("15m")
  refreshTokenExpiresIn      String   @default("7d")
  twoFactorEnabled           Boolean  @default(false)
  twoFactorRequired          Boolean  @default(false)
  twoFactorRequiredForAdmins Boolean  @default(false)
  twoFactorSuggested         Boolean  @default(true)
  emailVerificationRequired  Boolean  @default(false)
  emailVerificationLevel     String   @default("SOFT")
  passwordReuseLimit         Int      @default(5)
  sessionTimeoutMinutes      Int      @default(30)
  smtpUsername               String?
  smtpPassword               String?
  platformName               String?  @default("Sistema Multitenant")
  platformLogoUrl            String?
  platformEmail              String?
  platformPhone              String?
  webPushPublicKey           String?
  webPushPrivateKey          String?
  webPushSubject             String?  @default("mailto:suporte@example.com")
  rateLimitDevEnabled        Boolean  @default(false)
  rateLimitProdEnabled       Boolean  @default(false)
  rateLimitDevRequests       Int      @default(10000)
  rateLimitProdRequests      Int      @default(10000)
  rateLimitDevWindow         Int      @default(1)
  rateLimitProdWindow        Int      @default(1)
  tokenCleanupEnabled        Boolean  @default(true)
  tokenCleanupIntervalHours  Int      @default(24)
  maxActiveSessionsPerUser   Int      @default(5)
  refreshTokenRotation       Boolean  @default(true)
  backupRateLimitPerHour     Int      @default(5)
  restoreRateLimitPerHour    Int      @default(3)
  updateRateLimitPerHour     Int      @default(2)
  updatedAt                  DateTime @updatedAt
  updatedBy                  String?

  @@map("security_config")
}

model EmailConfiguration {
  id           String   @id @default(uuid())
  providerName String
  smtpHost     String
  smtpPort     Int
  encryption   String
  authMethod   String
  isActive     Boolean  @default(false)
  createdBy    String?
  updatedBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("email_configurations")
}

model SystemSetting {
  id              String   @id @default(uuid())
  key             String   @unique
  valueJson       Json
  valueType       String
  category        String
  scope           String   @default("system")
  tenantId        String?
  source          String   @default("seed_env")
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  version         Int      @default(1)

  @@index([category])
  @@index([scope])
  @@index([tenantId])
  @@index([scope, tenantId])
  @@map("system_settings")
}

model SystemSettingAudit {
  id              String   @id @default(uuid())
  settingKey      String
  oldValueJson    Json?
  newValueJson    Json?
  changedByUserId String?
  changedByEmail  String?
  changeReason    String?
  createdAt       DateTime @default(now())

  @@index([settingKey])
  @@index([createdAt])
  @@index([settingKey, createdAt])
  @@map("system_setting_audits")
}

model UpdateSystemSettings {
  id                 String    @id @default(uuid())
  appVersion         String?   @default("1.0.0")
  gitToken           String?
  gitUsername        String?
  gitRepository      String?
  gitReleaseBranch   String    @default("main")
  packageManager     String    @default("npm")
  updateCheckEnabled Boolean   @default(true)
  lastUpdateCheck    DateTime?
  availableVersion   String?
  updateAvailable    Boolean   @default(false)
  releaseTag         String?   @default("latest")
  composeFile        String?   @default("docker-compose.prod.yml")
  envFile            String?   @default("install/.env.production")
  updatedAt          DateTime  @updatedAt
  updatedBy          String?

  @@map("update_system_settings")
}

model UpdateLog {
  id             String    @id @default(uuid())
  version        String
  status         String
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  duration       Int?
  packageManager String    @default("npm")
  backupPath     String?
  errorMessage   String?
  rollbackReason String?
  executedBy     String?
  ipAddress      String?
  userAgent      String?
  executionLogs  String?

  @@index([status])
  @@index([startedAt])
  @@index([version])
  @@index([executedBy])
  @@map("update_logs")
}

model Module {
  id            String            @id @default(uuid())
  slug          String            @unique
  name          String
  version       String            @default("1.0.0")
  description   String?
  status        ModuleStatus      @default(detected)
  hasBackend    Boolean           @default(false)
  hasFrontend   Boolean           @default(false)
  installedAt   DateTime?
  activatedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  menus         ModuleMenu[]
  migrations    ModuleMigration[]
  npmDependencies ModuleNpmDependency[]
  tenantModules ModuleTenant[]

  @@index([status])
  @@index([slug])
  @@map("modules")
}

model ModuleMenu {
  id         String       @id @default(uuid())
  moduleId   String
  label      String
  icon       String?
  route      String
  parentId   String?
  order      Int          @default(0)
  permission String?
  isUserMenu Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  module     Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  parent     ModuleMenu?  @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children   ModuleMenu[] @relation("MenuHierarchy")

  @@index([moduleId])
  @@index([parentId])
  @@index([order])
  @@map("module_menus")
}

model ModuleTenant {
  id        String   @id @default(uuid())
  moduleId  String
  tenantId  String
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([moduleId, tenantId])
  @@index([tenantId])
  @@index([moduleId])
  @@index([enabled])
  @@map("module_tenant")
}

model ModuleMigration {
  id         String        @id @default(uuid())
  moduleId   String
  filename   String
  type       MigrationType
  executedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  module     Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, filename, type])
  @@index([moduleId])
  @@index([type])
  @@index([executedAt])
  @@map("module_migrations")
}

model ModuleNpmDependency {
  id          String                    @id @default(uuid())
  moduleId    String
  moduleSlug  String
  packageName String
  version     String
  target      ModuleNpmDependencyTarget
  status      ModuleNpmDependencyStatus @default(pending)
  note        String?
  createdBy   String?
  installedAt DateTime?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  module      Module                    @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, packageName, target])
  @@index([moduleSlug])
  @@index([status])
  @@index([target])
  @@map("module_npm_dependencies")
}

model Notification {
  id           String    @id @default(uuid())
  type         String    @default("SYSTEM_ALERT")
  severity     String
  title        String
  body         String?
  message      String
  data         Json      @default("{}")
  targetRole   String?   @default("SUPER_ADMIN")
  targetUserId String?
  isRead       Boolean   @default(false)
  read         Boolean   @default(false)
  readAt       DateTime?
  audience     String
  source       String
  module       String?
  tenantId     String?
  userId       String?
  context      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([tenantId])
  @@index([userId])
  @@index([targetUserId])
  @@index([targetRole])
  @@index([audience])
  @@index([severity])
  @@index([source])
  @@index([module])
  @@index([isRead])
  @@index([read])
  @@index([createdAt])
  @@index([tenantId, audience, read])
  @@index([userId, read])
  @@index([targetRole, isRead, createdAt])
  @@index([targetUserId, isRead, createdAt])
  @@map("notifications")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String?
  endpoint  String
  p256dh    String
  auth      String
  userAgent String?
  lastUsedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
  @@index([tenantId])
  @@index([updatedAt])
  @@map("push_subscriptions")
}

model SeedHistory {
  id          String        @id @default(cuid())
  executionId String
  seedKey     String
  module      String
  version     Int
  status      SeedRunStatus @default(STARTED)
  force       Boolean       @default(false)
  startedAt   DateTime      @default(now())
  finishedAt  DateTime?
  durationMs  Int?
  host        String?
  error       String?
  summary     Json?
  userId      String?
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([module, version, status])
  @@index([executionId])
  @@index([startedAt])
  @@index([userId])
  @@map("seed_history")
}

model SecureFile {
  id             String    @id @default(uuid())
  tenantId       String
  moduleName     String
  documentType   String
  originalName   String
  storedName     String
  mimeType       String
  sizeBytes      BigInt
  uploadedBy     String
  uploadedAt     DateTime  @default(now())
  lastAccessedAt DateTime?
  accessCount    Int       @default(0)
  deletedAt      DateTime?
  metadata       Json?

  @@index([tenantId])
  @@index([moduleName])
  @@index([uploadedBy])
  @@index([documentType])
  @@index([tenantId, moduleName, documentType])
  @@index([deletedAt])
  @@map("secure_files")
}

model CronSchedule {
  id            String   @id @default(uuid())
  origem        String
  modulo        String?
  identificador String
  descricao     String?
  expressao     String
  ativo         Boolean  @default(true)
  editavel      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([modulo, identificador])
  @@map("cron_schedules")
}

model CronJobHeartbeat {
  jobKey                  String   @id
  lastStartedAt           DateTime?
  lastHeartbeatAt         DateTime?
  lastSucceededAt         DateTime?
  lastFailedAt            DateTime?
  lastDurationMs          Int?
  lastStatus              String   @default("idle")
  lastError               String?
  nextExpectedRunAt       DateTime?
  consecutiveFailureCount Int      @default(0)
  updatedAt               DateTime @updatedAt
  cycleId                 String?
  instanceId              String?

  @@index([lastStatus])
  @@index([updatedAt])
  @@index([nextExpectedRunAt])
  @@map("cron_job_heartbeats")
}

model ExecutionLease {
  jobKey        String   @id
  ownerId       String
  cycleId       String
  status        String   @default("released")
  startedAt     DateTime
  heartbeatAt   DateTime
  lockedUntil   DateTime
  acquiredAt    DateTime @default(now())
  releasedAt    DateTime?
  releaseReason String?
  lastError     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, lockedUntil])
  @@index([ownerId])
  @@map("execution_leases")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
  CLIENT
}

enum ModuleStatus {
  detected
  installed
  db_ready
  uploaded
  pending_dependencies
  dependencies_installed
  dependency_conflict
  ready
  active
  disabled
}

enum ModuleNpmDependencyTarget {
  backend
  frontend
}

enum ModuleNpmDependencyStatus {
  pending
  installed
  conflict
}

enum MigrationType {
  migration
  seed
}

enum BackupOperation {
  BACKUP
  RESTORE
}

enum BackupStatus {
  STARTED
  SUCCESS
  FAILED
  CANCELLED
}

enum BackupArtifactSource {
  BACKUP
  UPLOAD
  SAFETY
}

enum BackupJobType {
  BACKUP
  RESTORE
}

enum BackupJobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELED
}

model BackupLog {
  id                String          @id @default(uuid())
  operationType     BackupOperation
  status            BackupStatus
  fileName          String
  fileSize          BigInt?
  startedAt         DateTime        @default(now())
  completedAt       DateTime?
  durationSeconds   Int?
  executedBy        String
  ipAddress         String?
  errorMessage      String?
  metadata          Json?
  user              User            @relation(fields: [executedBy], references: [id])

  @@index([operationType])
  @@index([status])
  @@index([executedBy])
  @@index([startedAt])
  @@map("backup_logs")
}

model BackupRestoreLog {
  id            String       @id @default(uuid())
  fileName      String
  status        RestoreStatus
  startedAt     DateTime     @default(now())
  completedAt   DateTime?
  stdout        String?
  stderr        String?
  executedBy    String
  rollbackReason String?
  errorMessage  String?
  metadata      Json?
  user          User         @relation(fields: [executedBy], references: [id])

  @@index([status])
  @@index([startedAt])
  @@index([executedBy])
  @@map("backup_restore_logs")
}

model BackupArtifact {
  id               String               @id @default(uuid())
  fileName         String
  filePath         String
  sizeBytes        BigInt
  checksumSha256   String
  source           BackupArtifactSource
  metadata         Json?
  createdAt        DateTime             @default(now())
  deletedAt        DateTime?
  createdByUserId  String?
  createdByUser    User?                @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  jobs             BackupJob[]          @relation("BackupArtifactJobs")

  @@index([source, createdAt])
  @@index([createdByUserId])
  @@index([deletedAt])
  @@map("backup_artifacts")
}

model BackupJob {
  id               String          @id @default(uuid())
  type             BackupJobType
  status           BackupJobStatus @default(PENDING)
  artifactId       String?
  fileName         String?
  filePath         String?
  sizeBytes        BigInt?
  checksumSha256   String?
  progressPercent  Int             @default(0)
  currentStep      String?
  metadata         Json?
  logs             Json?
  error            String?
  startedAt        DateTime?
  finishedAt       DateTime?
  lockAttempts     Int             @default(0)
  nextRunAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  cancelRequested  Boolean         @default(false)
  createdByUserId  String?
  createdByUser    User?           @relation("BackupJobCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  artifact         BackupArtifact? @relation("BackupArtifactJobs", fields: [artifactId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([status, nextRunAt, createdAt])
  @@index([type, status])
  @@index([artifactId])
  @@index([createdByUserId])
  @@index([cancelRequested])
  @@index([nextRunAt])
  @@map("backup_jobs")
}

model BackupLease {
  key           String        @id
  holderJobId   String?
  operationType BackupJobType?
  acquiredAt    DateTime?
  expiresAt     DateTime?
  updatedAt     DateTime      @updatedAt
  metadata      Json?

  @@index([expiresAt])
  @@map("backup_leases")
}

enum RestoreStatus {
  STARTED
  SUCCESS
  FAILED
}

enum SeedRunStatus {
  STARTED
  SUCCESS
  FAILED
  SKIPPED
  FORCED
}
