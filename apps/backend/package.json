{
  "name": "backend",
  "version": "0.1.69",
  "description": "Backend NestJS com segurança e isolamento multitenant - GOR Informática",
  "author": "GOR Informática <contato@gorinformatica.com.br>",
  "license": "AGPL-3.0",
  "homepage": "https://www.gorinformatica.com.br",
  "scripts": {
    "dev": "nest start --watch --exec \"ts-node -r tsconfig-paths/register src/main.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch --exec \"ts-node -r tsconfig-paths/register src/main.ts\"",
    "start:prod": "node dist/main.js",
    "build": "prisma generate && nest build",
    "test": "node .\\scripts\\ensure-prisma-client.js && node .\\scripts\\run-jest-cleanly.js",
    "test:security-regression": "jest src/security-regression/security-architecture.regression.spec.ts src/security-regression/critical-endpoints.regression.spec.ts src/core/security-config/security-runtime-config.service.spec.ts src/common/guards/security-throttler.guard.spec.ts src/common/services/redis-throttler.storage.spec.ts src/auth/auth.service.spec.ts src/auth/user-session.service.spec.ts src/prisma-seed/default-users.seed.spec.ts --runInBand",
    "test:smoke": "jest --config ./test/jest-smoke.json --runInBand --passWithNoTests",
    "prisma:generate": "pnpm exec prisma generate",
    "prisma:generate:test": "node .\\scripts\\ensure-prisma-client.js",
    "prisma:migrate": "prisma migrate deploy",
    "seed:deploy": "node dist/prisma/seed.js deploy",
    "seed:force": "node dist/prisma/seed.js deploy --force",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "security:audit": "pnpm audit --audit-level=moderate",
    "security:check": "pnpm run lint && pnpm run security:audit && pnpm run security:validate",
    "security:guardrails": "node ../../Scripts/tests/security-regression-guardrails.js",
    "security:regression": "pnpm run security:guardrails && pnpm run test:security-regression",
    "security:validate": "ts-node ../../scripts/backend/simple-security-check.ts",
    "security:full-scan": "ts-node ../../scripts/backend/security-check.ts",
    "security:snyk": "powershell -ExecutionPolicy Bypass -File ../../scripts/backend/snyk-test.ps1",
    "pre-deploy": "pnpm run security:check && pnpm run build"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.14",
    "@prisma/client": "6.19.2",
    "@sentry/node": "^8.55.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/adm-zip": "^0.5.7",
    "@types/qrcode": "^1.5.6",
    "@types/sanitize-html": "^2.16.0",
    "adm-zip": "^0.5.16",
    "bcrypt": "^6.0.0",
    "class-sanitizer": "^1.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cookie-parser": "^1.4.7",
    "cron": "^4.4.0",
    "express": "^5.2.1",
    "form-data": "^4.0.5",
    "googleapis": "^171.3.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "ms": "^2.1.3",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.13",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.19.0",
    "prisma": "6.19.2",
    "puppeteer": "^24.37.5",
    "qrcode": "^1.5.4",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.2",
    "sanitize-html": "^2.17.1",
    "semver": "^7.7.4",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "uuid": "^8.3.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/testing": "^11.1.14",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/ms": "^2.1.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.33",
    "@types/nodemailer": "^6.4.23",
    "@types/supertest": "^6.0.3",
    "@types/passport-jwt": "^4.0.1",
    "@types/semver": "^7.7.1",
    "@types/uuid": "^10.0.0",
    "@types/validator": "^13.15.10",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "axios": "^1.13.6",
    "dotenv": "^17.2.4",
    "eslint": "^9.39.2",
    "eslint-plugin-security": "^1.7.1",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "yn": "^3.1.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*(\\.spec|\\.e2e-spec)\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@core/(.*)$": "<rootDir>/core/$1",
      "^@modules/(.*)$": "<rootDir>/modules/$1",
      "^@common/(.*)$": "<rootDir>/common/$1",
      "^@config/(.*)$": "<rootDir>/config/$1",
      "^@database/(.*)$": "<rootDir>/database/$1",
      "^@security/(.*)$": "<rootDir>/security/$1"
    }
  },
  "overrides": {
    "diff": "^8.0.3",
    "multer": "^2.1.1",
    "socket.io-parser": "^4.2.6"
  },
  "prisma": {
    "seed": "node dist/prisma/seed.js"
  }
}
