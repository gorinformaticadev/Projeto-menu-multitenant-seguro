# Variables for install/install.sh
INSTALL_DOMAIN=__DOMAIN__
LETSENCRYPT_EMAIL=__EMAIL__
IMAGE_OWNER=__IMAGE_OWNER__
IMAGE_REPO=projeto-menu-multitenant-seguro
IMAGE_TAG=latest
APP_VERSION=latest
GIT_SHA=unknown
BUILD_TIME=unknown
INSTALL_ADMIN_EMAIL=__EMAIL__
INSTALL_ADMIN_PASSWORD=__ADMIN_PASSWORD__

DOMAIN=__DOMAIN__
FRONTEND_URL=https://__DOMAIN__
NEXT_PUBLIC_API_URL=https://__DOMAIN__/api
VIRTUAL_HOST=__DOMAIN__
LETSENCRYPT_HOST=__DOMAIN__

DB_USER=__DB_USER__
DB_PASSWORD=__DB_PASSWORD__
DB_NAME=__DB_NAME__
DATABASE_URL=postgresql://__DB_USER__:__DB_PASSWORD__@db:5432/__DB_NAME__?schema=public
# Usuario administrativo opcional para createdb/dropdb no restore staging
# Exemplo: postgresql://postgres:postgres123@db:5432/postgres?schema=public
BACKUP_ADMIN_DATABASE_URL=

JWT_SECRET=__JWT_SECRET__
ENCRYPTION_KEY=__ENCRYPTION_KEY__

NODE_ENV=production
PORT=4000
SEED_ON_START=true
SEED_FORCE=false
SEED_LOCK_ID=87456321
SEED_LOCK_WAIT_SECONDS=90
SEED_LOCK_RETRY_MS=2000
