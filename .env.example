# -----------------------------
# Configurações de Domínio
# -----------------------------
DOMAIN=__DOMAIN__
FRONTEND_URL=https://__DOMAIN__
BACKEND_URL=https://api.__DOMAIN__
NEXT_PUBLIC_API_URL=https://api.__DOMAIN__/api

# -----------------------------
# Banco de Dados
# -----------------------------
DB_USER=__DB_USER__
DB_PASSWORD=__DB_PASSWORD__
DB_NAME=__DB_NAME__

# -----------------------------
# Segredos
# -----------------------------
JWT_SECRET=__JWT_SECRET__
ENCRYPTION_KEY=__ENCRYPTION_KEY__

# -----------------------------
# Ambiente
# -----------------------------
NODE_ENV=production
PORT=4000

# -----------------------------
# Variáveis para proxy Nginx / acme-companion
# -----------------------------
VIRTUAL_HOST=__DOMAIN__
LETSENCRYPT_HOST=__DOMAIN__
LETSENCRYPT_EMAIL=__EMAIL__

# -----------------------------
# Backup / Restore (opcional)
# -----------------------------
# BACKUP_RESTORE_STRICT_UPLOAD_INSPECTION=true
# BACKUP_RESTORE_BLOCKED_OBJECT_TYPES=FUNCTION,PROCEDURE,AGGREGATE,EVENT TRIGGER,EXTENSION,LANGUAGE,FOREIGN DATA WRAPPER,SERVER,USER MAPPING,PUBLICATION,SUBSCRIPTION
# BACKUP_RESTORE_MAINTENANCE_WINDOW_SECONDS=1800
# BACKUP_RESTORE_RECONNECT_ATTEMPTS=6
# BACKUP_RESTORE_RECONNECT_DELAY_MS=2000
